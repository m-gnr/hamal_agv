    <!-- ================= SHORT PARKING-BARRIER STYLE CONTROLLED DOOR ================= -->
    <!-- This replaces the tall wall-like door. It is a short barrier arm like parking entrance gates. -->
    <model name="controlled_door">
      <static>true</static>
      <pose>0.05 -1.25 0 0 0 0</pose>

      <!-- Pivot post -->
      <link name="gate_post">
        <pose>0 -0.62 0.35 0 0 0</pose>
        <collision name="collision">
          <geometry>
            <box><size>0.16 0.16 0.70</size></box>
          </geometry>
