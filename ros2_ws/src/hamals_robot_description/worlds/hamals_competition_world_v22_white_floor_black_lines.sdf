          </geometry>
          <material>
            <ambient>0.02 0.02 0.02 1</ambient>
            <diffuse>0.02 0.02 0.02 1</diffuse>
          </material>
        </visual>
      </link>

      <!-- Short barrier arm across the white route line -->
      <link name="gate_arm">
        <pose>0 0 0.58 0 0 0</pose>
        <collision name="collision">
          <geometry>
            <box><size>0.10 0.95 0.08</size></box>
